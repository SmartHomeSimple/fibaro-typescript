{
  "name": "@smarthomesimple/fibaro-typescript",
  "version": "0.1.0",
  "type": "module",
  "description": "TypeScript client for Fibaro Home Center API",
  "license": "Apache-2.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup ./src/index.ts --format esm,cjs --clean && tsc -p tsconfig.build.json --emitDeclarationOnly --declaration --declarationMap false --declarationDir dist --noCheck",
    "prepublishOnly": "npm run build",
    "download:swagger": "node ./scripts/download-swagger.js",
    "pregenerate:merge": "node ./scripts/premerge.js",
    "generate:merge": "openapi-merge-cli --config openapi-merge.json",
    "generate:sdk": "openapi-ts",
    "generate": "npm run generate:merge && npm run generate:sdk",
    "example:get-devices": "tsx ./examples/get-devices.ts",
    "test": "tsx --test ./tests/**/*.test.ts",
    "test:nodes-neighbors": "tsx --test ./tests/nodes-neighbors.test.ts"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.94.5",
    "openapi-merge-cli": "^1.3.2",
    "openapi-typescript": "^7.13.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1",
    "dotenv": "^17.3.1"
  }
}
